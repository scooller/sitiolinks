# URL del backend Laravel - cambiar según entorno
VITE_BACKEND_URL=http://127.0.0.1:8000

# Pusher Broadcasting (obtén credenciales en https://dashboard.pusher.com)
# Deben coincidir con las del backend (.env de Laravel)
VITE_PUSHER_APP_KEY=
VITE_PUSHER_APP_CLUSTER=mt1
# Optional: Admin panel URL (Filament/Laravel)
VITE_ADMIN_URL=http://127.0.0.1:8000/admin
